# Copy this file to `.env` and fill in your values.
# DO NOT commit `.env` — the token grants full account access.

# Your Discord user token (Network tab → authorization header).
DISCORD_TOKEN=paste_your_discord_token_here

# Optional: comma- or space-separated IDs to skip.
# Get IDs by enabling Settings → Advanced → Developer Mode, then
# right-click a server or user → "Copy ID".
#
# Guilds listed here are skipped entirely.
EXCLUDE_GUILDS=
# Users listed here cause their 1:1 DMs and any group DMs they're in to be skipped.
EXCLUDE_USERS=

# Example with three guilds and two users:
#   EXCLUDE_GUILDS=123456789012345678, 987654321098765432, 111222333444555666
#   EXCLUDE_USERS=555666777888999000 444333222111000999
